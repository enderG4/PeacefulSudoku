<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PeacefulSudoku.WinDialog"
        Width="360" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        TransparencyLevelHint="AcrylicBlur">

    <Border Background="#111111"
            CornerRadius="20"
            Padding="40,36">

        <StackPanel Spacing="0">

            <!-- top label -->
            <TextBlock Text="PUZZLE SOLVED"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#3A3A3A" LetterSpacing="4"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- big time -->
            <TextBlock x:Name="TimeLabel"
                       FontSize="52" FontWeight="Bold"
                       Foreground="#4ADE80"
                       HorizontalAlignment="Center"
                       FontFamily="Consolas,monospace"
                       Margin="0,0,0,8"/>

            <!-- difficulty -->
            <TextBlock x:Name="DiffLabel"
                       FontSize="12"
                       Foreground="#444444"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- divider -->
            <Border Height="1" Background="#1E1E1E" Margin="0,0,0,24"/>

            <!-- buttons -->
            <Grid ColumnDefinitions="*,12,*">
                <Button Grid.Column="0"
                        Content="quit"
                        Click="Quit_Click"
                        HorizontalAlignment="Stretch"
                        Classes="act"/>
                <Button Grid.Column="2"
                        Content="new game"
                        Click="NewGame_Click"
                        HorizontalAlignment="Stretch"
                        Classes="new"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>